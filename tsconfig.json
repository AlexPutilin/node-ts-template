{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "types": ["node"],
    "rootDir": "src",
    "outDir": "build",
    "baseUrl": ".",
    "paths": {
      "#app/*": ["src/*"]
    },
    "esModuleInterop": true,
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "build"]
}